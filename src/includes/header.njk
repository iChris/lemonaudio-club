<header role="banner" class="w-full p-4 bg-gray-100 flex items-center justify-between">
    <a href="{{ build.url }}" rel="home" class="text-lg font-bold leading-tight">{{ meta.title }}</a>
    <nav role="navigation" tabindex="-1" aria-label="Main">
        {%- if page.url == '/' -%}
        <ul class="flex items-center space-x-4 sm:space-x-6 text-sm sm:text-base">
            <li><a href="#watch" class="hover:underline">Watch</a></li>
            <li class="hidden sm:block"><a href="#about" class="hover:underline">About</a></li>
            <li class="hidden sm:block"><a href="#what" class="hover:underline">What you get</a></li>
            <li><a href="#join" class="inline-block bg-yellow-400 hover:bg-yellow-300 text-gray-900 font-bold rounded px-3 py-1">Join</a></li>
        </ul>
        {%- else -%}
        <ul class="flex align-center spacing-x-4">
        {%- for item in collections.all | eleventyNavigation -%}
            {%- set isCurrent = (item.url == page.url) -%}
            {%- set isParent = item.url != '/' and item.url in page.url -%}
            <li>
                <a
                    href="{% if isCurrent %}#content{% else %}{{ item.url | url }}{% endif %}"
                    {% if isCurrent %}aria-current="page"{% endif %}
                >
                    {{ item.title }}
                </a>
            </li>
        {%- endfor -%}
        </ul>
        {%- endif -%}
    </nav>
</header>